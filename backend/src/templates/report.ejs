<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Clinical Risk Assessment Report</title>
  <style>
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; margin: 0; padding: 40px; background-color: #fff; }
    .header { border-bottom: 2px solid #5a67d8; padding-bottom: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; }
    .title h1 { margin: 0; font-size: 28px; color: #1a202c; letter-spacing: -0.5px; }
    .title p { margin: 5px 0 0; font-size: 14px; color: #718096; }
    .meta { font-size: 13px; color: #4a5568; text-align: right; }
    
    .section { border-radius: 8px; border: 1px solid #e2e8f0; padding: 25px; margin-bottom: 30px; display: flex; align-items: center; justify-content: space-between; }
    .risk-score { text-align: center; }
    .risk-score .num { font-size: 48px; font-weight: 800; color: #5a67d8; line-height: 1; }
    .risk-score .label { font-size: 14px; color: #718096; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-top: 5px; }
    
    .risk-cat { font-size: 22px; font-weight: 600; color: #2d3748; }
    .risk-cat span { background: #ebf4ff; color: #4c51bf; padding: 4px 12px; border-radius: 20px; font-size: 16px; margin-left: 10px; }

    .factors-box { margin-bottom: 30px; }
    .factors-box h3 { border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; margin-top: 0; font-size: 18px; color: #2d3748; }
    .factor-item { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #edf2f7; }
    .factor-item:last-child { border: none; }
    .factor-name { font-weight: 500; color: #4a5568; text-transform: capitalize; }
    .factor-val { font-weight: 700; color: #5a67d8; }

    .rec-box h3 { border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; margin-top: 0; font-size: 18px; color: #2d3748; }
    .rec-box ul { padding-left: 20px; color: #4a5568; font-size: 15px; line-height: 1.6; }
    .rec-box li { margin-bottom: 10px; }

    .footer { margin-top: 50px; font-size: 11px; color: #a0aec0; text-align: center; border-top: 1px solid #e2e8f0; padding-top: 20px; }
  </style>
</head>
<body>

  <div class="header">
    <div class="title">
      <h1>Clinical Risk Profile</h1>
      <p>GlucoPulse AI Diagnostics Engine</p>
    </div>
    <div class="meta">
      <strong>Patient ID:</strong> <%= userId.substring(0, 8) %><br>
      <strong>Generation Date:</strong> <%= date %>
    </div>
  </div>

  <div class="section">
    <div class="risk-cat">
      Assessment Tier: <span><%= category %></span>
    </div>
    <div class="risk-score">
      <div class="num"><%= riskScore %>%</div>
      <div class="label">Progression Probability</div>
    </div>
  </div>

  <div class="factors-box">
    <h3>Primary Biological Drivers</h3>
    <% factors.slice(0, 5).forEach(function(factor) { %>
      <div class="factor-item">
        <div class="factor-name"><%= factor.factor %></div>
        <div class="factor-val"><%= factor.impact %></div>
      </div>
    <% }); %>
  </div>

  <div class="rec-box">
    <h3>AI Protocol Interventions</h3>
    <ul>
      <% recommendations.forEach(function(rec) { %>
        <li><%= rec %></li>
      <% }); %>
    </ul>
  </div>

  <div class="footer">
    This clinical report was programmatically generated by GlucoPulse AI and does not serve as a replacement for qualified medical advice.
  </div>

</body>
</html>
